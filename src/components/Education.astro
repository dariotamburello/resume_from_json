---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import HeaderTitle from "./common/HeaderTitle.astro";
import Calendar from "src/icons/Calendar.astro";
import WorldMap from "src/icons/WorldMap.astro";
const { education } = Astro.props.cv;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section>
  <HeaderTitle icon="🎓">{t("education.title")}</HeaderTitle>
  {
    education.map((edu) => (
      <div class="flex flex-col mt-2.5 pl-2 text-neutral-800 dark:text-neutral-300">
        <div class="flex flex-row gap-2 mb-0">
          <p class="text-xs flex items-center gap-1">
            <Calendar /> {edu.startDate} - {edu.endDate}
          </p>
          <p class="text-xs flex items-center gap-1">
            <WorldMap /> {edu.location}
          </p>
        </div>
        <div>
          <h2 class="text-base mb-0.5 font-bold">{edu.institute}</h2>
          <p class="text-xs">{edu.degree}</p>
        </div>
      </div>
    ))
  }
</section>
